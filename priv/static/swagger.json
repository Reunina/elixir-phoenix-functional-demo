        "last_name": {
          "description": "Last name",
          "type": "string"
        }
      },
      "required": [
        "last_name",
        "first_name",
        "id"
      ],
      "title": "User",
      "type": "object"
    },
    "ErrorObject": {
      "properties": {
        "message": {
