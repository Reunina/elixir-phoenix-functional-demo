{
  "info": {
    "version": "1.0",
    "title": "Turbo Octo Pancakes API"
  },
  "host": "localhost:4000",
  "definitions": {
    "User": {
      "description": "A user in the system",
      "example": {
        "first_name": "Mock",
        "id": "mock-id-1",
        "last_name": "User",
        "proucts": [
          {
            "amount": 100000,
            "currency": "USD",
            "id": "prouct-id-1",
            "label": "Base prouct",
            "start_date": "2025-01-01T00:00:00Z",
            "stock": 0
          }
        ]
      },
      "properties": {
        "first_name": {
          "description": "First name",
          "type": "string"
        },
        "id": {
          "description": "User ID",
          "type": "string"
        },
        "last_name": {
          "description": "Last name",
          "type": "string"
        },
        "proucts": {
          "description": "List of user proucts",
          "items": {
            "$ref": "#/definitions/Product"
          },
          "type": "array"
        }
      },
      "required": [
        "proucts",
        "last_name",
        "first_name",
        "id"
      ],
      "title": "User",
      "type": "object"
    },
    "Product": {
      "description": "A prouct entry for a user",
      "properties": {
        "amount": {
          "description": "Product amount in minor units (e.g. cents)",
          "type": "integer"
        },
        "currency": {
          "description": "ISO 4217 currency code",
          "type": "string"
        },
        "end_date": {
          "description": "End date (ISO8601)",
          "type": "string"
        },
        "id": {
          "description": "Product ID",
          "type": "string"
        },
        "label": {
          "description": "Product label",
          "type": "string"
        },
        "start_date": {
          "description": "Start date (ISO8601)",
          "type": "string"
        },
        "stock": {
          "description": "Associated stock units",
          "type": "integer"
        }
      },
      "required": [
        "start_date",
        "currency",
        "stock",
        "amount",
        "label",
        "id"
      ],
      "title": "Product",
      "type": "object"
    },
    "UsersIndexResponse": {
      "properties": {
        "users": {
          "description": "List of users",
          "items": {
            "$ref": "#/definitions/User"
          },
          "type": "array"
        }
      },
      "required": [
        "users"
      ],
      "title": "Users index response",
      "type": "object"
    },
    "ErrorResponse": {
      "properties": {
        "error": {
          "$ref": "#/definitions/ErrorObject",
          "description": "Error payload"
        }
      },
      "required": [
        "error"
      ],
      "title": "Error response wrapper",
      "type": "object"
    },
    "ErrorObject": {
      "properties": {
        "message": {
          "description": "Error message",
          "type": "string"
        }
      },
      "required": [
        "message"
      ],
      "title": "Error",
      "type": "object"
    }
  },
  "tags": [
    {
      "name": "Users",
      "description": "List and filter users"
    }
  ],
  "paths": {
    "/users": {
      "get": {
        "description": "Returns all users ordered by full name (first_name then last_name).",
        "operationId": "TurboOctoPancakesWeb.UserController.index",
        "parameters": [
          {
            "description": "Filter users by first name, last name, or full name (case-insensitive)",
            "in": "query",
            "name": "name",
            "required": false,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/UsersIndexResponse"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        },
        "summary": "List users",
        "tags": [
          "Users"
        ]
      }
    }
  },
  "swagger": "2.0"
}